# ---- Supabase (same project as the Electron app so chats/journals are shared) ----
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# ---- Grok (x.ai) ----
XAI_API_KEY=xai-...
XAI_MODEL=grok-4

# ---- Admin panel passcode (protects /admin) ----
ADMIN_PASSCODE=change-me-to-something-long

# ---- Optional: public base url used when building share links ----
# If omitted, links are built from the incoming request host.
NEXT_PUBLIC_SITE_URL=
